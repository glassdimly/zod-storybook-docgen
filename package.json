{
  "name": "zod-storybook-docgen",
  "version": "0.2.0",
  "description": "Auto-generate Storybook argTypes from Zod schemas. Fills the gap where react-docgen can't understand z.infer<typeof schema>.",
  "license": "MIT",
  "author": "Jeremy John <glassdimly@gmail.com> (https://github.com/glassdimly)",
  "repository": {
    "type": "git",
    "url": "https://github.com/glassdimly/zod-storybook-docgen.git"
  },
  "homepage": "https://github.com/glassdimly/zod-storybook-docgen#readme",
  "bugs": {
    "url": "https://github.com/glassdimly/zod-storybook-docgen/issues"
  },
  "keywords": [
    "storybook",
    "zod",
    "argTypes",
    "docgen",
    "controls",
    "addon",
    "react",
    "schema",
    "codemod",
    "migration"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./migrate": {
      "types": "./dist/migrate.d.ts",
      "import": "./dist/migrate.js"
    }
  },
  "bin": {
    "zod-storybook-docgen": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "fast-glob": "^3.3.3",
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.25.0"
  }
}
